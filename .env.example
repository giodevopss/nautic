# MongoDB (local: mongodb://127.0.0.1:27017/nautic | Atlas/Railway: copie a connection string completa)
DATABASE_URL="mongodb://127.0.0.1:27017/nautic"

API_PORT=3001

# URL pública da API Express (browser: reservas e /admin). Em produção use a URL do serviço API no Railway.
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Segredo do painel /admin (Authorization: Bearer … na API)
ADMIN_SECRET="troque-em-producao"

# Tokens de sessão do login no site
AUTH_SECRET="troque-em-producao"
