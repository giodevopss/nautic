# MongoDB — o segmento após :porta é OBRIGATÓRIO (/nautic). Sem isso o Prisma falha com P1013.
# Se o Railway só der host:porta, o script prisma-db-push + API acrescentam "/nautic" (ou MONGO_DATABASE).
DATABASE_URL="mongodb://127.0.0.1:27017/nautic"
# MONGO_DATABASE="nautic"

API_PORT=3001

# URL pública da API Express (browser: reservas e /admin). Em produção use a URL do serviço API no Railway.
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Opcional — base pública onde estão /videos/* e /images/* (Railway Bucket, R3, CDN). Sem barra final.
# Ex.: https://xxxxxxxx.up.railway.app  → o site usa https://....../videos/heroes.mp4
# NEXT_PUBLIC_MEDIA_URL=""

# Envio de mídia para Tigris (npm run upload:media) — não commite chaves
# STORAGE_ENDPOINT="https://t3.storageapi.dev"
# STORAGE_BUCKET="wrapped-pannikin-ta6us77k"
# STORAGE_ACCESS_KEY=""
# STORAGE_SECRET_KEY=""
# AWS_REGION="auto"
# Se o upload falhar com 301/Signature, tente: STORAGE_FORCE_PATH_STYLE=false

# Segredo do painel /admin (Authorization: Bearer … na API)
ADMIN_SECRET="troque-em-producao"

# Tokens de sessão do login no site
AUTH_SECRET="troque-em-producao"
